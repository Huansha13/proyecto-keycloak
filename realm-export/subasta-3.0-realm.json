{
  "realm": "subasta-3.0",
  "enabled": true,
  "displayName": "Subasta 3.0",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "defaultSignatureAlgorithm": "RS256",
  "revokeRefreshToken": false,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "actionTokenGeneratedByAdminLifespan": 43200,
  "actionTokenGeneratedByUserLifespan": 300,
  "internationalizationEnabled": true,
  "supportedLocales": ["es", "en"],
  "defaultLocale": "es",
  "passwordPolicy": "length(8) and upperCase(1) and lowerCase(1) and digits(1) and specialChars(1)",
  "clients": [
    {
      "clientId": "subasta-client",
      "name": "Subasta Client",
      "description": "Client para microservicios de subastas",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "subasta-secret-key-2025",
      "protocol": "openid-connect",
      "publicClient": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "defaultClientScopes": [
        "openid",
        "profile",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "user-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "roles",
            "claim.name": "roles",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "jsonType.label": "String",
            "multivalued": "true",
            "aggregateAttributeValues": "false"
          }
        },
        {
          "name": "user-name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "name",
            "claim.name": "name",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "jsonType.label": "String",
            "multivalued": "false",
            "aggregateAttributeValues": "false"
          }
        },
        {
          "name": "preferred-username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "preferred_username",
            "claim.name": "preferred_username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "jsonType.label": "String",
            "multivalued": "false",
            "aggregateAttributeValues": "false"
          }
        },
        {
          "name": "user-oid",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "oid",
            "claim.name": "oid",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "jsonType.label": "String",
            "multivalued": "false",
            "aggregateAttributeValues": "false"
          }
        },
        {
          "name": "user-scp",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "scp",
            "claim.name": "scp",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "jsonType.label": "String",
            "multivalued": "false",
            "aggregateAttributeValues": "false"
          }
        }
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "openid",
      "description": "OpenID Connect scope",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": []
    },
    {
      "name": "profile",
      "description": "Profile scope",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": []
    },
    {
      "name": "email",
      "description": "Email scope",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": []
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "ADMINISTRADOR",
        "description": "Rol de administrador del sistema"
      },
      {
        "name": "AUDITOR",
        "description": "Rol de auditor del sistema"
      },
      {
        "name": "SUBASTADOR",
        "description": "Rol de subastador del sistema"
      },
      {
        "name": "POSTOR",
        "description": "Rol de postor del sistema"
      }
    ]
  }
}
